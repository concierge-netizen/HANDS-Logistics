<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HANDS Logistics — Internal Tools</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>

:root{--black:#0a0a0a;--dark:#111111;--card:#161616;--card2:#1c1c1c;--border:#2a2a2a;--border2:#333;--green:#a0d6b4;--label:#777;--body:#e0e0e0;--muted:#555;--font-h:"Bebas Neue",sans-serif;--font-b:"DM Sans",sans-serif}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:var(--dark);color:var(--body);font-family:var(--font-b)}
.site-hdr{background:var(--black);height:60px;display:flex;align-items:center;justify-content:space-between;padding:0 36px;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100}
.site-hdr img{height:30px;display:block}
.site-hdr-r{display:flex;align-items:center;gap:20px}
.site-time{font-size:12px;color:var(--label);letter-spacing:.5px}
.abar{height:3px;display:flex;flex-shrink:0}
.abar .d{flex:0 0 68%;background:var(--black)}
.abar .g{flex:0 0 32%;background:var(--green)}
.hero{background:linear-gradient(180deg,#0d0d0d 0%,var(--dark) 100%);border-bottom:1px solid var(--border);padding:40px 36px 32px}
.hero-lbl{font-size:11px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--green);margin-bottom:8px}
.hero-title{font-family:var(--font-h);font-size:38px;letter-spacing:3px;color:#fff;line-height:1;margin-bottom:8px}
.hero-sub{font-size:14px;color:var(--label)}
.main{max-width:1100px;margin:0 auto;padding:40px 36px 80px}
.sec-hdr{display:flex;align-items:center;gap:12px;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid var(--border)}
.sec-hdr h2{font-family:var(--font-h);font-size:20px;letter-spacing:2px;color:#fff}
.sec-count{font-size:11px;font-weight:600;letter-spacing:1px;background:var(--border2);color:var(--label);padding:2px 8px;border-radius:2px}
.tool-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;margin-bottom:48px}
.tc{background:var(--card);border:1px solid var(--border);border-radius:4px;padding:24px;cursor:pointer;transition:border-color .2s,background .2s,transform .15s;text-decoration:none;display:flex;flex-direction:column;position:relative;overflow:hidden}
.tc::before{content:"";position:absolute;top:0;left:0;right:0;height:2px;background:var(--green);opacity:0;transition:opacity .2s}
.tc:hover{border-color:var(--border2);background:var(--card2);transform:translateY(-2px)}
.tc:hover::before{opacity:1}
.tc-icon{width:40px;height:40px;border-radius:3px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;flex-shrink:0}
.tc-icon svg{display:block}
.tc-tag{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:6px}
.tc-name{font-family:var(--font-h);font-size:20px;letter-spacing:1.5px;color:#fff;margin-bottom:6px;line-height:1.1}
.tc-desc{font-size:12px;color:var(--label);line-height:1.6;flex:1;margin-bottom:16px}
.tc-ftr{display:flex;align-items:center;justify-content:space-between;padding-top:14px;border-top:1px solid var(--border)}
.tc-meta{font-size:10px;color:var(--muted)}
.tc-arr{width:28px;height:28px;border-radius:2px;border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;transition:border-color .2s,background .2s}
.tc:hover .tc-arr{border-color:var(--green);background:rgba(160,214,180,.08)}
.tc-arr svg{display:block}
.ic-green{background:rgba(160,214,180,.12)}
.ic-blue{background:rgba(100,160,220,.12)}
.ic-amber{background:rgba(230,180,80,.12)}
.ic-purple{background:rgba(200,140,220,.12)}
.tag-ops{color:#a0d6b4}
.tag-driver{color:#64a0dc}
.tag-client{color:#e6b450}
.tag-wh{color:#c88cdc}
.badge{display:inline-flex;align-items:center;gap:4px;font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:2px 8px;border-radius:2px}
.badge-live{background:rgba(160,214,180,.15);color:var(--green)}
.badge-dot{width:5px;height:5px;border-radius:50%;background:currentColor;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.ql-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:48px}
.ql{background:var(--card);border:1px solid var(--border);border-radius:3px;padding:8px 16px;font-size:12px;font-weight:500;color:var(--label);text-decoration:none;letter-spacing:.5px;transition:border-color .2s,color .2s;display:flex;align-items:center;gap:6px}
.ql:hover{border-color:var(--green);color:var(--green)}
.ql svg{display:block}
.site-ftr{background:var(--black);border-top:1px solid var(--border);padding:20px 36px;display:flex;align-items:center;justify-content:space-between}
.ftr-l{font-size:11px;color:var(--muted);letter-spacing:.5px}
.ftr-r{font-size:11px;color:var(--green);letter-spacing:2px;font-family:var(--font-h)}
.dim{cursor:default;opacity:.5}

/* ── PENDING TASKS ── */
.tasks-section{margin-bottom:48px}
.tasks-wrap{background:var(--card);border:1px solid var(--border);border-radius:4px;overflow:hidden}
.tasks-table{width:100%;border-collapse:collapse}
.tasks-table th{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--label);padding:10px 18px;text-align:left;border-bottom:1px solid var(--border);background:#1a1a1a}
.tasks-table td{padding:11px 18px;font-size:13px;border-bottom:1px solid rgba(42,42,42,.5);vertical-align:middle}
.tasks-table tr:last-child td{border-bottom:none}
.tasks-table tr:hover td{background:rgba(255,255,255,.02)}
.task-name a{color:var(--body);font-weight:500;text-decoration:none}
.task-name a:hover{color:var(--green)}
.task-dl{font-size:12px;font-weight:700;white-space:nowrap}
.dl-overdue{color:#e07070}.dl-today{color:#e6b450}.dl-soon{color:#a0d6b4}.dl-future{color:var(--label)}
.task-badge{display:inline-flex;font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:2px 8px;border-radius:2px;white-space:nowrap}
.tb-ip{background:rgba(253,171,61,.12);color:#fdab3d}
.tb-sched{background:rgba(100,120,200,.12);color:#8899ee}
.tb-info{background:rgba(224,112,112,.12);color:#e07070}
.tasks-footer{display:flex;align-items:center;justify-content:space-between;padding:9px 18px;border-top:1px solid var(--border);background:#111}
.tasks-ts{font-size:11px;color:var(--muted)}
.tasks-btn{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--green);background:none;border:1px solid rgba(160,214,180,.2);border-radius:2px;padding:3px 10px;cursor:pointer;transition:border-color .2s,background .2s}
.tasks-btn:hover{border-color:var(--green);background:rgba(160,214,180,.06)}
.tasks-msg{padding:28px 18px;text-align:center;font-size:13px;color:var(--muted);font-style:italic}
</style>
</head>
<body>
