      <div class="tc-ftr"><span class="badge badge-live"><span class="badge-dot"></span>Live</span><div class="tc-arr"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#a0d6b4" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg></div></div>
    </a>

    <a class="tc" href="https://assignpurpose.netlify.app" target="_blank">
      <div class="tc-icon ic-blue"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#64a0dc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg></div>
      <div class="tc-tag tag-driver">Client Portal</div>
      <div class="tc-name">Warehouse I/O</div>
