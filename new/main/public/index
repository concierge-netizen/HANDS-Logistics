    <span class="site-time" id="clock"></span>
    <span class="site-time">Internal Tools</span>
  </div>
</header>
<div class="abar"><div class="d"></div><div class="g"></div></div>

<div class="hero">
  <div class="hero-lbl">HANDS Logistics &mdash; Operations Hub</div>
  <div class="hero-title">Internal Tools</div>
  <div class="hero-sub">All warehouse and delivery tools in one place &mdash; password protected</div>
</div>

<main class="main">

  <div class="ql-row">
