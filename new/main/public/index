<script>
function tick(){
  var d=new Date(),h=d.getHours(),m=d.getMinutes(),s=d.getSeconds();
  var ap=h>=12?'PM':'AM';h=h%12||12;
  document.getElementById('clock').textContent=
    (h<10?'0':'')+h+':'+(m<10?'0':'')+m+':'+(s<10?'0':'')+s+' '+ap;
}
tick();setInterval(tick,1000);

var ENDPOINT   = '/.netlify/functions/pending-tasks';
var BOARD_ID   = '4550650855';
var SHOW       = ['IN PROGRESS','DELIVERY SCHEDULED','INFORMATION NEEDED'];
var REFRESH_MS = 5*60*1000;

function dlClass(ds){
  if(!ds)return 'dl-future';
  var p=ds.split(' ')[0].split('-');
  var dl=new Date(+p[0],+p[1]-1,+p[2]),today=new Date();
  today.setHours(0,0,0,0);
  var d=Math.round((dl-today)/86400000);
  if(d<0)return 'dl-overdue';
  if(d===0)return 'dl-today';
  if(d<=4)return 'dl-soon';
  return 'dl-future';
}
function dlLabel(ds){
  if(!ds)return '—';
  var p=ds.split(' ')[0].split('-');
  var dl=new Date(+p[0],+p[1]-1,+p[2]),today=new Date();
  today.setHours(0,0,0,0);
  var d=Math.round((dl-today)/86400000);
  var fmt=dl.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
  if(d<0)return fmt+' <span style="font-size:9px;opacity:.6">(overdue)</span>';
  if(d===0)return 'Today';
  if(d===1)return 'Tomorrow';
  return fmt;
}
function stBadge(s){
  var u=(s||'').toUpperCase();
  var cls='tb-ip';
  if(u.indexOf('SCHEDULED')!==-1)cls='tb-sched';
  if(u.indexOf('INFORMATION')!==-1)cls='tb-info';
  return '<span class="task-badge '+cls+'">'+s+'</span>';
}

function loadTasks(){
  var tbody=document.getElementById('tasksTbody');
  var countEl=document.getElementById('taskCount');
  var tsEl=document.getElementById('tasksTs');
  tbody.innerHTML='<tr><td colspan="4" class="tasks-msg">Fetching live data…</td></tr>';
  countEl.textContent='loading…';

  fetch(ENDPOINT)
    .then(function(r){
      if(!r.ok) throw new Error('Function returned '+r.status);
      return r.json();
    })
    .then(function(data){
      if(data.error) throw new Error(data.error);

      var items=data.items.filter(function(it){
        return SHOW.indexOf((it.status||'').toUpperCase().trim())!==-1;
      });

      countEl.textContent=items.length+' active';

      if(!items.length){
        tbody.innerHTML='<tr><td colspan="4" class="tasks-msg">No active deliveries with deadlines found.</td></tr>';
        return;
      }

      var rows='';
      items.forEach(function(it){
        var url='https://handslogistics.monday.com/boards/'+BOARD_ID+'/pulses/'+it.id;
        rows+='<tr>'
          +'<td class="task-name"><a href="'+url+'" target="_blank">'+it.name+'</a></td>'
          +'<td><span class="task-dl '+dlClass(it.date||'')+'">'+dlLabel(it.date||'')+'</span></td>'
          +'<td>'+stBadge(it.status||'')+'</td>'
          +'<td style="font-size:12px;color:var(--label)">'+(it.account||'—')+'</td>'
          +'</tr>';
      });
      tbody.innerHTML=rows;

      var now=new Date();
      tsEl.textContent='Updated '+now.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'})+' · auto-refreshes every 5 min';
    })
    .catch(function(err){
      tbody.innerHTML='<tr><td colspan="4" class="tasks-msg">Could not load data: '+err.message+'</td></tr>';
      countEl.textContent='error';
      console.error('loadTasks:',err);
    });
}

loadTasks();
setInterval(loadTasks,REFRESH_MS);
</script>
</body>
</html>
