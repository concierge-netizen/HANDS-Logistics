  <div class="tool-grid">

    <a class="tc" href="https://handslabel.netlify.app/" target="_blank">
      <div class="tc-icon ic-purple"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c88cdc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg></div>
      <div class="tc-tag tag-wh">Warehouse</div>
